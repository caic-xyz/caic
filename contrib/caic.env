# caic environment configuration
# Copy to ~/.config/caic/caic.env and edit as needed.
# The systemd service (caic.service) loads this file automatically.

# ── Core ─────────────────────────────────────────────────────────────────────

# HTTP listen address for the web UI. (required)
#CAIC_HTTP=:8080

# Parent directory containing git repositories managed by caic. (required)
# ⏩️ Adjust as needed. Defaults to the current directory. For systemd, the current working directory is
# specified in caic.service.
#CAIC_ROOT=.

# Log level: debug, info, warn, error.
#CAIC_LOG_LEVEL=info

# ── LLM features (title generation, commit descriptions) ─────────────────────

# Provider: anthropic, gemini, openaichat, etc.
# See https://pkg.go.dev/github.com/maruel/genai/providers
#CAIC_LLM_PROVIDER=
#CAIC_LLM_MODEL=

# ── GitHub ────────────────────────────────────────────────────────────────────

# PAT — single-user / headless. Mutually exclusive with GitHub OAuth.
# Create at https://github.com/settings/personal-access-tokens/new?name=my+caic+instance&description=caic+PR+creation+and+CI+monitoring&pull_requests=write&checks=read&expires_in=365
# Required permissions: pull_requests:write, checks:read
# If unset and gh CLI is in PATH (and OAuth is not configured), caic uses
# the token from `gh auth token` automatically. No explicit value needed
# when gh is already authenticated.
#GITHUB_TOKEN=

# OAuth — multi-user login. Mutually exclusive with GITHUB_TOKEN.
# See https://docs.caic.xyz/caic/ for OAuth app setup instructions.
#GITHUB_OAUTH_CLIENT_ID=
#GITHUB_OAUTH_CLIENT_SECRET=
# Comma-separated GitHub users allowed to login. Highly recommended.
# Example: alice,bob
#GITHUB_OAUTH_ALLOWED_USERS=

# GitHub App — org-wide webhooks and automatic task creation.
# Layered on top of PAT or OAuth; not mutually exclusive with either.
# Create at https://github.com/settings/apps/new?name=my+caic+instance&webhook_active=true&issues=write&pull_requests=write&checks=read&events[]=issues&events[]=pull_request&events[]=issue_comment&events[]=check_suite
# See https://docs.caic.xyz/caic/ for GitHub App setup instructions.
#GITHUB_APP_ID=
# Example: private-key.pem
#GITHUB_APP_PRIVATE_KEY_PEM=
# Generate with: openssl rand -hex 32
#GITHUB_WEBHOOK_SECRET=
# Comma-separated GitHub owners/orgs allowed to install the app. Installs from
# other accounts are rejected automatically. Highly recommended. Leave unset to allow all installs.
# Example: my-org,my-username
#GITHUB_APP_ALLOWED_OWNERS=

# ── GitLab ────────────────────────────────────────────────────────────────────

# PAT — single-user / headless. Mutually exclusive with GitLab OAuth.
# Create at https://gitlab.com/-/user_settings/personal_access_tokens?name=my+caic+instance&scopes=api
# Required scope: api
#GITLAB_TOKEN=

# OAuth — multi-user login. Mutually exclusive with GITLAB_TOKEN.
# See https://docs.caic.xyz/caic/ for OAuth app setup instructions.
#GITLAB_OAUTH_CLIENT_ID=
#GITLAB_OAUTH_CLIENT_SECRET=
# Comma-separated GitLab users allowed to login. Highly recommended.
# Example: alice,bob
#GITLAB_OAUTH_ALLOWED_USERS=

# GitLab instance URL. Default: https://gitlab.com
#GITLAB_URL=https://gitlab.com

# Webhook CI — real-time pipeline status. See https://docs.caic.xyz/caic/ for Webhook CI.
# Generate with: openssl rand -hex 32
#GITLAB_WEBHOOK_SECRET=

# ── Exposure (OAuth login and webhooks) ───────────────────────────────────────

# Public base URL. Default "auto" locks the hostname from the first FQDN request.
# Set an explicit URL for OAuth login and GitHub webhooks.
# Can be a public HTTPS domain or a Tailscale Funnel / serve URL.
# See https://docs.caic.xyz/caic/ for HTTPS exposure options.
# Example: https://caic.example.com or https://caic.my-tailnet.ts.net
#CAIC_EXTERNAL_URL=auto

# ── Agents ────────────────────────────────────────────────────────────────────

# Gemini API key — required for the Gemini Live voice agent.
# Obtain from https://aistudio.google.com/app/apikey
#GEMINI_API_KEY=

# Tailscale API key — required for Tailscale ephemeral node.
# Obtain from https://login.tailscale.com/admin/settings/keys
#TAILSCALE_API_KEY=

# UDP port for WebRTC ICE (single-port mux). Unset disables WebRTC voice.
# Requires libopus-dev at build time (CGO_ENABLED=1).
# Open this port in your firewall for UDP traffic.
# Example: 3478
#CAIC_WEBRTC_PORT=

# ── Auto-update ──────────────────────────────────────────────────────────────

# Nightly auto-update from GitHub Releases (04:50 local time).
# Set to "0" to disable. Enabled by default for release builds.
#CAIC_AUTO_UPDATE=0

# ── IP geolocation (optional) ─────────────────────────────────────────────────

# Path to a MaxMind MMDB file for country-code resolution and logging.
# Download GeoLite2-Country.mmdb from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Relative paths are resolved against ~/.config/caic/.
# When set, every request log line includes the resolved country code ("cc").
# Example: GeoLite2-Country.mmdb
#CAIC_IPGEO_DB=

# Comma-separated allowlist of permitted values. Requests from IPs that do not
# match are rejected with HTTP 403.
# Named origins: "local" (loopback/private), "tailscale" (100.64.0.0/10),
#   "github" (GitHub webhook IPs fetched from api.github.com/meta).
# CIDR ranges: e.g. 203.0.113.0/24.
# Country codes: ISO 3166-1 alpha-2 (e.g. CA, US, DE); requires CAIC_IPGEO_DB.
# To allow all IPs: 0.0.0.0/0,::/0
#CAIC_IPGEO_ALLOWLIST=local,tailscale,github
